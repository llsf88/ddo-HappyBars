<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
		<UseWindowsForms>true</UseWindowsForms>
		<Platforms>x64</Platforms>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<Authors>Slick</Authors>
		<Company>HappyBars</Company>
		<Product>HappyBars</Product>
		<Version>1.0.0</Version>
		<RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
		<Configurations>Debug;Release;LocalDevDebug</Configurations>
		<AssemblyName>HappyBars</AssemblyName>
		<RootNamespace>UiRuler</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="VoK.Sdk" Version="4.0.7" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="images\HappyBarsIcon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>HappyBarsIcon.png</TargetPath>
		</Content>
		<Content Include="images\HappyBarsToolbarIcon.png">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>HappyBarsToolbarIcon.png</TargetPath>
		</Content>
	</ItemGroup>

	<ItemGroup>
	  <Compile Update="Properties\Resources.Designer.cs">
	    <DesignTime>True</DesignTime>
	    <AutoGen>True</AutoGen>
	    <DependentUpon>Resources.resx</DependentUpon>
	  </Compile>
	</ItemGroup>

	<ItemGroup>
	  <EmbeddedResource Update="Properties\Resources.resx">
	    <Generator>ResXFileCodeGenerator</Generator>
	    <LastGenOutput>Resources.Designer.cs</LastGenOutput>
	  </EmbeddedResource>
	</ItemGroup>

	<Target Name="PostBuildDevDebug" AfterTargets="Build" Condition="'$(Obfuscation)' != 'false' And '$(Configuration)'=='LocalDevDebug'">
		<Exec WorkingDirectory="$(OutDir)" Command="copy * $(ProjectDir)..\..\..\dungeon-helper\src\VoK.DungeonHelper\bin\x64\Debug\net8.0-windows10.0.17763.0\win-x64\plugins\HappyBars\ " />
		<Exec Command="del ..\\..\\..\\dungeon-helper\\src\\VoK.DungeonHelper\\bin\\x64\\Debug\\net8.0-windows10.0.17763.0\\win-x64\\plugins\\HappyBars\\System.Drawing.Common.dll" />
	</Target>

	<Target Name="PostBuildDebug" AfterTargets="Build" Condition="'$(Configuration)'=='Debug'">
		<Exec Command="if not exist &quot;%USERPROFILE%\AppData\Roaming\Dungeon Helper\plugins\HappyBars&quot; (mkdir &quot;%USERPROFILE%\AppData\Roaming\Dungeon Helper\plugins\HappyBars&quot;)" />
		<Exec WorkingDirectory="$(OutDir)" Command="copy * &quot;%USERPROFILE%\AppData\Roaming\Dungeon Helper\plugins\HappyBars\&quot; " />
		<Exec Command="del &quot;%USERPROFILE%\AppData\Roaming\Dungeon Helper\plugins\HappyBars\System.Drawing.Common.dll&quot;" />
	</Target>

</Project>
